# Public Supabase configuration used by the browser bundle.
# The publishable key is intentionally public, but it must still be supplied per environment.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=

# Server-side Supabase configuration.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_PROJECT_ID=
SUPABASE_JWKS_URL=

# Server-only. Never expose this value through a VITE_ variable or commit a real value.
SUPABASE_SERVICE_ROLE_KEY=

# Canonical public origin used when generating team-access links.
APP_BASE_URL=http://localhost:3000
